 # =====================================================
# SUPABASE
# =====================================================
# Get these from: Supabase Dashboard → Settings → API Keys
# Use the "Publishable and secret API keys" tab (NOT the legacy tab)

# Public — safe to expose to browser  
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret — NEVER expose to browser
# 
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================
# DATABASE (Prisma)
# =====================================================
# Get these from: Supabase Dashboard → Settings → Database → Connection string

# Pooled connection (Transaction mode, port 6543) — for runtime queries on Vercel
# Append: ?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Direct connection (Session mode, port 5432) — for Prisma migrations only
DIRECT_URL=

# =====================================================
# APP
# =====================================================
NEXT_PUBLIC_APP_URL=